  display: block;\n    margin-bottom: 2px;\n  }\n  .type-btn.selected .type-name { color: #fff; }\n  .type-btn.shoutout.selected .type-name { color: var(--color-black); }\n  .type-desc { font-size: 11px; color: #888; font-family: var(--font-body); line-height: 1.3; }\n  .type-btn.selected .type-desc { color: #aaa; }\n  .type-btn.shoutout.selected .type-desc { color: #555; }\n\n  /* SUBTYPE */\n  .subtype-card {\n    background: #fafafa;\n    border: 2px solid #ddd;\n    padding: 16px 18px;\n    margin-top: 12px;\n    display: none;\n  }\n  .subtype-card.visible { display: block; }\n  .subtype-card-label {\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: #888;\n    font-family: var(--font-header);\n    margin-bottom: 10px;\n  }\n  .subtype-row { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }\n\n  .chip {\n    border: 2px solid #ccc;\n    background: #fafafa;\n    font-family: var(--font-header);\n    font-weight: 600;\n    font-size: 12px;\n    letter-spacing: 0.03em;\n    padding: 7px 14px;\n    cursor: pointer;\n    transition: all 0.1s;\n    outline: none;\n    border-radius: 0;\n    color: var(--color-black);\n  }\n  .chip:hover { border-color: var(--color-black); background: #eee; }\n  .chip.selected { background: var(--color-black); border-color: var(--color-black); color: #fff; }\n  .chip.shoutout.selected { background: var(--color-yellow); border-color: var(--color-black); color: var(--color-black); }\n\n  /* ADD CHIP */\n  .add-chip-btn {\n    border: 2px dashed #bbb;\n    background: transparent;\n    font-family: var(--font-header);\n    font-weight: 600;\n    font-size: 11px;\n    letter-spacing: 0.04em;\n    padding: 6px 12px;\n    cursor: pointer;\n    color: #aaa;\n    border-radius: 0;\n    transition: all 0.1s;\n    outline: none;\n    white-space: nowrap;\n  }\n  .add-chip-btn:hover { border-color: var(--color-black); color: var(--color-black); }\n  .add-chip-input-wrap { display: none; align-items: center; gap: 6px; }\n  .add-chip-input-wrap.open { display: flex; }\n  .add-chip-input {\n    border: 2px solid var(--color-black) !important;\n    font-size: 12px !important;\n    padding: 5px 10px !important;\n    width: 140px !important;\n    box-shadow: none !important;\n  }\n  .add-chip-confirm {\n    background: var(--color-black);\n    color: #fff;\n    border: 2px solid var(--color-black);\n    font-family: var(--font-header);\n    font-weight: 700;\n    font-size: 11px;\n    padding: 5px 10px;\n    cursor: pointer;\n    border-radius: 0;\n    outline: none;\n    white-space: nowrap;\n  }\n  .add-chip-confirm:hover { background: var(--color-yellow); color: var(--color-black); }\n  .add-chip-cancel {\n    background: transparent;\n    border: none;\n    font-size: 16px;\n    cursor: pointer;\n    color: #aaa;\n    padding: 4px;\n    line-height: 1;\n  }\n  .add-chip-cancel:hover { color: var(--color-black); }\n\n  /* TOGGLE */\n  .toggle-row {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    padding: 14px 16px;\n    border: 2px solid #eee;\n    background: #fafafa;\n    cursor: pointer;\n    user-select: none;\n    transition: border-color 0.12s;\n  }\n  .toggle-row:hover { border-color: var(--color-black); }\n  .toggle-row.on { border-color: var(--color-black); background: #fff; box-shadow: 3px 3px 0 var(--color-yellow); }\n  .toggle-switch {\n    width: 40px; height: 22px;\n    background: #ccc;\n    border: 2px solid var(--color-black);\n    border-radius: 0;\n    position: relative;\n    flex-shrink: 0;\n    transition: background 0.15s;\n  }\n  .toggle-row.on .toggle-switch { background: var(--color-yellow); }\n  .toggle-knob {\n    position: absolute;\n    width: 12px; height: 12px;\n    background: var(--color-black);\n    top: 3px; left: 3px;\n    transition: left 0.15s;\n  }\n  .toggle-row.on .toggle-knob { left: 21px; }\n  .toggle-label { font-family: var(--font-header); font-weight: 600; font-size: 13px; color: var(--color-black); display: block; }\n  .toggle-hint { font-size: 12px; color: #888; font-family: var(--font-body); }\n\n  /* SUBMIT */\n  .btn-submit {\n    width: 100%;\n    background: var(--color-black);\n    color: var(--color-yellow);\n    border: 2px solid var(--color-black);\n    font-family: var(--font-header);\n    font-weight: 800;\n    font-size: 14px;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    padding: 16px;\n    cursor: pointer;\n    transition: all 0.12s;\n    outline: none;\n    border-radius: 0;\n    margin-top: 8px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 10px;\n  }\n  .btn-submit:hover { background: var(--color-yellow); color: var(--color-black); box-shadow: 4px 4px 0 var(--color-black); }\n  .btn-submit:active { transform: translate(2px,2px); box-shadow: none; }\n  .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; }\n  .spinner {\n    width: 16px; height: 16px;\n    border: 2px solid rgba(255,206,0,0.3);\n    border-top-color: var(--color-yellow);\n    border-radius: 50%;\n    animation: spin 0.7s linear infinite;\n    display: none;\n  }\n  .btn-submit.loading .spinner { display: block; }\n  .btn-submit.loading .btn-text::after { content: \"Saving…\"; }\n  .btn-submit:not(.loading) .btn-text::after { content: \"Submit Incident →\"; }\n  @keyframes spin { to { transform: rotate(360deg); } }\n\n  /* SUCCESS */\n  .success-screen { display: none; text-align: center; padding: 48px 24px; }\n  .success-screen.visible { display: block; }\n  .success-icon {\n    width: 64px; height: 64px;\n    background: var(--color-yellow);\n    border: 2px solid var(--color-black);\n    box-shadow: 4px 4px 0 var(--color-black);\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 28px;\n    margin-bottom: 20px;\n  }\n  .success-title { font-family: var(--font-display); font-weight: 900; font-size: 1.8rem; margin-bottom: 8px; }\n  .success-sub { font-size: 15px; color: #666; margin-bottom: 28px; line-height: 1.6; }\n  .btn-another {\n    background: var(--color-yellow);\n    border: 2px solid var(--color-black);\n    box-shadow: 3px 3px 0 var(--color-black);\n    font-family: var(--font-header);\n    font-weight: 700;\n    font-size: 13px;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    padding: 12px 28px;\n    cursor: pointer;\n    border-radius: 0;\n    transition: all 0.1s;\n  }\n  .btn-another:hover { background: var(--color-black); color: var(--color-yellow); }\n\n  /* SCRIPT NOTICE */\n  .script-notice {\n    background: #fffbe6;\n    border: 2px solid var(--color-gold);\n    padding: 12px 16px;\n    margin-bottom: 14px;\n    font-size: 13px;\n    color: #555;\n    font-family: var(--font-body);\n    line-height: 1.5;\n  }\n  .script-notice strong { font-weight: 700; color: var(--color-black); }\n  .script-notice code { font-family: monospace; font-size: 12px; background: #f0e68c; padding: 1px 4px; }\n\n  /* VALIDATION */\n  .hint { font-size: 12px; color: var(--color-coral); margin-top: 5px; display: none; font-family: var(--font-body); }\n  .field.error input, .field.error select, .field.error textarea { border-color: var(--color-coral); }\n  .field.error .hint { display: block; }\n<\u002Fstyle>\n\n<\u002Fhead>\n<body>\n\n<header class=\"header\">\n  <span class=\"header-badge\">Revolution School<\u002Fspan>\n  <span class=\"header-sep\"><\u002Fspan>\n  <span class=\"header-title\">Student Incident Log<\u002Fspan>\n<\u002Fheader>\n\n<main class=\"main\">\n  <div id=\"formWrap\">\n    <h1 class=\"page-heading\">Log an Event<\u002Fh1>\n    <p class=\"page-sub\">All required fields marked <span style=\"color:var(--color-coral)\">*<\u002Fspan><\u002Fp>\n\n    <!-- APPS SCRIPT NOTICE -->\n    <div class=\"script-notice\" id=\"scriptNotice\">\n      <strong>⚠️ Not yet saving to Google Sheets.<\u002Fstrong> Follow the 5-minute setup below, then paste your URL and this notice disappears.\n      <button id=\"setupToggleBtn\" style=\"margin-left:10px; background:var(--color-gold); border:2px solid var(--color-black); font-family:var(--font-header); font-weight:700; font-size:11px; letter-spacing:0.06em; padding:4px 10px; cursor:pointer; border-radius:0;\">SHOW SETUP ▾<\u002Fbutton>\n    <\u002Fdiv>\n\n    <!-- SETUP GUIDE -->\n    <div id=\"setupGuide\" style=\"display:none; background:#fff; border:2px solid var(--color-black); box-shadow:4px 4px 0 var(--color-black); padding:24px; margin-bottom:14px; font-family:var(--font-body); font-size:14px; line-height:1.7;\">\n      <div style=\"font-family:var(--font-header); font-weight:800; font-size:13px; letter-spacing:0.08em; text-transform:uppercase; margin-bottom:16px;\">Google Sheets Setup — 5 minutes<\u002Fdiv>\n      <ol style=\"padding-left:20px; color:#333;\">\n        <li style=\"margin-bottom:10px;\">Open your Google Sheet → click <strong>Extensions<\u002Fstrong> → <strong>Apps Script<\u002Fstrong><\u002Fli>\n        <li style=\"margin-bottom:10px;\">Delete any existing code and paste this into <strong>Code.gs<\u002Fstrong>:<br>\n          <div style=\"position:relative; margin-top:8px;\">\n            <pre id=\"codeBlock\" style=\"background:#f4f4f4; border:2px solid #ddd; padding:14px; font-family:monospace; font-size:12px; overflow-x:auto; white-space:pre; line-height:1.6;\">function doPost(e) {\n  const data = JSON.parse(e.postData.contents);\n  const sheet = SpreadsheetApp\n    .getActiveSpreadsheet()\n    .getActiveSheet();\n  sheet.appendRow([\n    data.submitted,\n    data.date,\n    data.time,\n    data.teacher,\n    data.student,\n    data.type,\n    data.subtype,\n    data.notes,\n    data.friday\n  ]);\n  return ContentService.createTextOutput('ok');\n}<\u002Fpre>\n            <button onclick=\"copyCode()\" style=\"position:absolute; top:8px; right:8px; background:var(--color-black); color:var(--color-yellow); border:none; font-family:var(--font-header); font-weight:700; font-size:11px; letter-spacing:0.06em; padding:5px 10px; cursor:pointer; border-radius:0;\" id=\"copyCodeBtn\">Copy<\u002Fbutton>\n          <\u002Fdiv>\n        <\u002Fli>\n        <li style=\"margin-bottom:10px;\">Click <strong>Deploy<\u002Fstrong> → <strong>New deployment<\u002Fstrong> → set type to <strong>Web app<\u002Fstrong><br>\n          <span style=\"color:#666; font-size:13px;\">Execute as: <strong>Me<\u002Fstrong> &nbsp;|&nbsp; Who has access: <strong>Anyone<\u002Fstrong><\u002Fspan>\n        <\u002Fli>\n        <li style=\"margin-bottom:10px;\">Click <strong>Deploy<\u002Fstrong>, authorize if prompted, then <strong>copy the Web App URL<\u002Fstrong><\u002Fli>\n        <li>Paste it below and click Save:<\u002Fli>\n      <\u002Fol>\n      <div style=\"display:flex; gap:8px; margin-top:12px; flex-wrap:wrap;\">\n        <input type=\"text\" id=\"urlInput\" placeholder=\"https://script.google.com/macros/s/…/exec\" style=\"flex:1; min-width:200px; border:2px solid var(--color-black); padding:9px 12px; font-family:var(--font-body); font-size:13px; border-radius:0; outline:none;\">\n        <button onclick=\"saveUrl()\" style=\"background:var(--color-black); color:var(--color-yellow); border:2px solid var(--color-black); font-family:var(--font-header); font-weight:700; font-size:12px; letter-spacing:0.06em; padding:9px 18px; cursor:pointer; border-radius:0; white-space:nowrap;\">Save URL<\u002Fbutton>\n      <\u002Fdiv>\n      <div id=\"urlSaved\" style=\"display:none; color:green; font-size:13px; margin-top:8px; font-weight:600;\">✓ URL saved! Submissions will now go to your sheet.<\u002Fdiv>\n    <\u002Fdiv>\n\n    <!-- WHO & WHEN -->\n    <div class=\"card\">\n      <div class=\"card-section-label\">Who &amp; When<\u002Fdiv>\n\n      <div class=\"field\" id=\"f-student\">\n        <label>Student Name <span class=\"req\">*<\u002Fspan><\u002Flabel>\n        <div class=\"autocomplete-wrap\">\n          <input type=\"text\" id=\"student\" placeholder=\"Type to search…\" autocomplete=\"off\" oninput=\"acFilter()\" onkeydown=\"acKey(event)\" onfocus=\"acFilter()\" onblur=\"acBlur()\">\n          <div class=\"autocomplete-list\" id=\"acList\"><\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"hint\">Please select a student.<\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"field\" id=\"f-teacher\">\n        <label>Your Name <span class=\"req\">*<\u002Fspan><\u002Flabel>\n        <div class=\"select-wrap\">\n          <select id=\"teacher\">\n            <option value=\"\">— Select your name —<\u002Foption>\n            <option>Ah-Keisha<\u002Foption>\n            <option>Anna<\u002Foption>\n            <option>Carolyn<\u002Foption>\n            <option>Dirk<\u002Foption>\n            <option>Gina<\u002Foption>\n            <option>Joel<\u002Foption>\n            <option>Katherine<\u002Foption>\n            <option>Michael<\u002Foption>\n            <option>Syd<\u002Foption>\n          <\u002Fselect>\n        <\u002Fdiv>\n        <div class=\"hint\">Please select your name.<\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"two-col\">\n        <div class=\"field\" id=\"f-date\">\n          <label>Date <span class=\"req\">*<\u002Fspan><\u002Flabel>\n          <input type=\"date\" id=\"date\">\n          <div class=\"hint\">Please pick a date.<\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"field\">\n          <label>Time<\u002Flabel>\n          <input type=\"time\" id=\"time\">\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <!-- INCIDENT TYPE -->\n    <div class=\"card\">\n      <div class=\"card-section-label\">Incident Type <span style=\"color:var(--color-coral)\">*<\u002Fspan><\u002Fdiv>\n\n      <div class=\"type-grid\" id=\"typeGrid\">\n        <button type=\"button\" class=\"type-btn\" data-type=\"preparation\" onclick=\"selectType(this)\">\n          <span class=\"type-emoji\">📋<\u002Fspan>\n          <span class=\"type-name\">Preparation<\u002Fspan>\n          <span class=\"type-desc\">Readiness for class<\u002Fspan>\n        <\u002Fbutton>\n        <button type=\"button\" class=\"type-btn\" data-type=\"communication\" onclick=\"selectType(this)\">\n          <span class=\"type-emoji\">💬<\u002Fspan>\n          <span class=\"type-name\">Communication<\u002Fspan>\n          <span class=\"type-desc\">Language &amp; behavior<\u002Fspan>\n        <\u002Fbutton>\n        <button type=\"button\" class=\"type-btn\" data-type=\"engagement\" onclick=\"selectType(this)\">\n          <span class=\"type-emoji\">👁<\u002Fspan>\n          <span class=\"type-name\">Engagement<\u002Fspan>\n          <span class=\"type-desc\">Attention &amp; participation<\u002Fspan>\n        <\u002Fbutton>\n        <button type=\"button\" class=\"type-btn\" data-type=\"display\" onclick=\"selectType(this)\">\n          <span class=\"type-emoji\">📝<\u002Fspan>\n          <span class=\"type-name\">Display of Learning<\u002Fspan>\n          <span class=\"type-desc\">Academic performance<\u002Fspan>\n        <\u002Fbutton>\n        <button type=\"button\" class=\"type-btn shoutout\" data-type=\"shoutout\" onclick=\"selectType(this)\" style=\"grid-column: span 2;\">\n          <span class=\"type-emoji\">⭐<\u002Fspan>\n          <span class=\"type-name\">Positive Shoutout<\u002Fspan>\n          <span class=\"type-desc\">Celebrate something great<\u002Fspan>\n        <\u002Fbutton>\n      <\u002Fdiv>\n\n      <div id=\"hint-type\" class=\"hint\" style=\"display:none; margin-top:8px;\">Please select an incident type.<\u002Fdiv>\n\n      <!-- SUBTYPE PANELS -->\n      <div class=\"subtype-card\" id=\"sub-preparation\">\n        <div class=\"subtype-card-label\">Subtype<\u002Fdiv>\n        <div class=\"subtype-row\" id=\"chips-preparation\">\n          <button type=\"button\" class=\"chip\" data-sub=\"Late\" onclick=\"selectChip(this,'preparation')\">Late<\u002Fbutton>\n          <button type=\"button\" class=\"chip\" data-sub=\"Unprepared\" onclick=\"selectChip(this,'preparation')\">Unprepared<\u002Fbutton>\n        <\u002Fdiv>\n        <div style=\"margin-top:10px;\" id=\"addrow-preparation\"><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"subtype-card\" id=\"sub-communication\">\n        <div class=\"subtype-card-label\">Subtype<\u002Fdiv>\n        <div class=\"subtype-row\" id=\"chips-communication\">\n          <button type=\"button\" class=\"chip\" data-sub=\"Bad Language\" onclick=\"selectChip(this,'communication')\">Bad Language<\u002Fbutton>\n          <button type=\"button\" class=\"chip\" data-sub=\"Refusal / Shutdown\" onclick=\"selectChip(this,'communication')\">Refusal / Shutdown<\u002Fbutton>\n          <button type=\"button\" class=\"chip\" data-sub=\"Social\" onclick=\"selectChip(this,'communication')\">Social<\u002Fbutton>\n        <\u002Fdiv>\n        <div style=\"margin-top:10px;\" id=\"addrow-communication\"><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"subtype-card\" id=\"sub-engagement\">\n        <div class=\"subtype-card-label\">Subtype<\u002Fdiv>\n        <div class=\"subtype-row\" id=\"chips-engagement\">\n          <button type=\"button\" class=\"chip\" data-sub=\"Distracted\" onclick=\"selectChip(this,'engagement')\">Distracted<\u002Fbutton>\n          <button type=\"button\" class=\"chip\" data-sub=\"Left Class\" onclick=\"selectChip(this,'engagement')\">Left Class<\u002Fbutton>\n          <button type=\"button\" class=\"chip\" data-sub=\"On Screen\" onclick=\"selectChip(this,'engagement')\">On Screen<\u002Fbutton>\n          <button type=\"button\" class=\"chip\" data-sub=\"Sleeping\" onclick=\"selectChip(this,'engagement')\">Sleeping<\u002Fbutton>\n        <\u002Fdiv>\n        <div style=\"margin-top:10px;\" id=\"addrow-engagement\"><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"subtype-card\" id=\"sub-display\">\n        <div class=\"subtype-card-label\">Subtype<\u002Fdiv>\n        <div class=\"subtype-row\" id=\"chips-display\">\n          <button type=\"button\" class=\"chip\" data-sub=\"Failed Assessment\" onclick=\"selectChip(this,'display')\">Failed Assessment<\u002Fbutton>\n          <button type=\"button\" class=\"chip\" data-sub=\"No Homework\" onclick=\"selectChip(this,'display')\">No Homework<\u002Fbutton>\n          <button type=\"button\" class=\"chip\" data-sub=\"Cheating / AI\" onclick=\"selectChip(this,'display')\">Cheating / AI<\u002Fbutton>\n        <\u002Fdiv>\n        <div style=\"margin-top:10px;\" id=\"addrow-display\"><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div class=\"subtype-card\" id=\"sub-shoutout\">\n        <div class=\"subtype-card-label\">Reason<\u002Fdiv>\n        <div class=\"subtype-row\" id=\"chips-shoutout\">\n          <button type=\"button\" class=\"chip shoutout\" data-sub=\"Helped Someone\" onclick=\"selectChip(this,'shoutout')\">Helped Someone<\u002Fbutton>\n          <button type=\"button\" class=\"chip shoutout\" data-sub=\"Great Attitude\" onclick=\"selectChip(this,'shoutout')\">Great Attitude<\u002Fbutton>\n          <button type=\"button\" class=\"chip shoutout\" data-sub=\"Above and Beyond\" onclick=\"selectChip(this,'shoutout')\">Above and Beyond<\u002Fbutton>\n        <\u002Fdiv>\n        <div style=\"margin-top:10px;\" id=\"addrow-shoutout\"><\u002Fdiv>\n      <\u002Fdiv>\n\n      <div id=\"hint-sub\" class=\"hint\" style=\"display:none; margin-top:8px;\">Please select a subtype.<\u002Fdiv>\n    <\u002Fdiv>\n\n    <!-- NOTES -->\n    <div class=\"card\">\n      <div class=\"card-section-label\">Details<\u002Fdiv>\n\n      <div class=\"field\">\n        <label>Additional Notes<\u002Flabel>\n        <textarea id=\"notes\" placeholder=\"Any context, what happened, what was said…\"><\u002Ftextarea>\n      <\u002Fdiv>\n\n      <div class=\"field\">\n        <label>Friday Meeting<\u002Flabel>\n        <div class=\"toggle-row\" id=\"fridayToggle\" onclick=\"toggleFriday()\">\n          <div class=\"toggle-switch\"><div class=\"toggle-knob\"><\u002Fdiv><\u002Fdiv>\n          <div>\n            <span class=\"toggle-label\">Discuss at Friday meeting<\u002Fspan>\n            <span class=\"toggle-hint\">Flag this for the weekly PCED check-in<\u002Fspan>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <button class=\"btn-submit\" type=\"button\" id=\"submitBtn\" onclick=\"submitForm()\">\n      <div class=\"spinner\"><\u002Fdiv>\n      <span class=\"btn-text\"><\u002Fspan>\n    <\u002Fbutton>\n  <\u002Fdiv>\n\n  <!-- SUCCESS -->\n  <div class=\"success-screen\" id=\"successScreen\">\n    <div class=\"success-icon\">✓<\u002Fdiv>\n    <div class=\"success-title\">Incident Logged<\u002Fdiv>\n    <p class=\"success-sub\" id=\"successDetail\"><\u002Fp>\n    <button class=\"btn-another\" onclick=\"resetForm()\">Log Another<\u002Fbutton>\n  <\u002Fdiv>\n<\u002Fmain>\n\n<script>\n// ─── CONFIGURATION ───────────────────────────────────────────────────────────\nlet APPS_SCRIPT_URL = localStorage.getItem('rs_script_url') || '';\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst STUDENTS = [\n  'Ali Washington','Amelia Holmes','Amitai Bravato','Aniyah Ruiz','Asher Jayawardena',\n  'Ava Laforest','Aylin Smith','Camryn Smith','Cassie Stewart','Chaelin Song',\n  'Cole Anthony','Daeshawn Quinones','Grant McCants-Green','Hailey Perez','Huei-Chiao Yang',\n  'Ines Balti','Isaac Fernandez','Isir Thomas',\"J'Lynn Savage\",'Jacob Fernandez',\n  'January Faust','Jenna Johnson-Moore','Jingheng Zhang','Jordyn Barnes','Julian Smith',\n  'Kai-Lang Yang','Kenneth Davis','Kimora Allen','Layla Haines','Lena Haynie',\n  'Luca Harper','Mariam Abdulrahman','Miyanah William-Devlin','Naasirah Washington',\n  'Precious Morrow','Ruqi Jiang','Tina Ellis','Xiang Ni','Yasmeen Taylor',\n  'Zafirah Acuna','Zhiyuan Qian','Zion Walker'\n];\n\n// Per-type custom subtypes (persisted in localStorage)\nconst STORAGE_KEY = 'rs_custom_subtypes';\nlet customSubtypes = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');\n\nlet selectedType = null;\nlet selectedSub = null;\nlet fridayOn = false;\nlet acActiveIdx = -1;\n\n// Defaults\ndocument.getElementById('date').valueAsDate = new Date();\nconst now = new Date();\ndocument.getElementById('time').value =\n  String(now.getHours()).padStart(2,'0') + ':' + String(now.getMinutes()).padStart(2,'0');\n\n// Hide notice if URL already configured\nif (APPS_SCRIPT_URL) document.getElementById('scriptNotice').style.display = 'none';\n\n// Setup guide toggle\ndocument.getElementById('setupToggleBtn').addEventListener('click', function() {\n  const g = document.getElementById('setupGuide');\n  const open = g.style.display === 'block';\n  g.style.display = open ? 'none' : 'block';\n  this.textContent = open ? 'SHOW SETUP ▾' : 'HIDE SETUP ▴';\n});\n\nfunction copyCode() {\n  const code = document.getElementById('codeBlock').textContent;\n  navigator.clipboard.writeText(code).then(() => {\n    const btn = document.getElementById('copyCodeBtn');\n    btn.textContent = 'Copied!';\n    setTimeout(() => btn.textContent = 'Copy', 2000);\n  });\n}\n\nfunction saveUrl() {\n  const val = document.getElementById('urlInput').value.trim();\n  if (!val.startsWith('https://')) {\n    alert('Please paste a valid Apps Script URL starting with https://');\n    return;\n  }\n  APPS_SCRIPT_URL = val;\n  localStorage.setItem('rs_script_url', val);\n  document.getElementById('urlSaved').style.display = 'block';\n  document.getElementById('scriptNotice').style.display = 'none';\n}\n\n// ─── AUTOCOMPLETE ─────────────────────────────────────────────────────────────\nfunction acFilter() {\n  const val = document.getElementById('student').value.trim().toLowerCase();\n  const list = document.getElementById('acList');\n  const matches = val\n    ? STUDENTS.filter(s => s.toLowerCase().includes(val))\n    : STUDENTS;\n\n  if (!matches.length) { list.classList.remove('open'); return; }\n  acActiveIdx = -1;\n  list.innerHTML = matches.map((s, i) => {\n    const hi = val ? s.replace(new RegExp(`(${val.replace(/[.*+?^${}()|[\\]\\\\]/g,'\\\\$&')})`, 'gi'), '<mark>$1<\u002Fmark>') : s;\n    return `<div class=\"ac-item\" data-idx=\"${i}\" data-val=\"${s}\" onmousedown=\"acPick('${s.replace(/'/,\"\\\\'\")}')\">` + hi + '<\u002Fdiv>';\n  }).join('');\n  list.classList.add('open');\n}\n\nfunction acPick(name) {\n  document.getElementById('student').value = name;\n  document.getElementById('acList').classList.remove('open');\n  document.getElementById('f-student').classList.remove('error');\n}\n\nfunction acBlur() {\n  setTimeout(() => document.getElementById('acList').classList.remove('open'), 150);\n}\n\nfunction acKey(e) {\n  const list = document.getElementById('acList');\n  const items = list.querySelectorAll('.ac-item');\n  if (e.key === 'ArrowDown') {\n    acActiveIdx = Math.min(acActiveIdx + 1, items.length - 1);\n    items.forEach((it, i) => it.classList.toggle('active', i === acActiveIdx));\n    e.preventDefault();\n  } else if (e.key === 'ArrowUp') {\n    acActiveIdx = Math.max(acActiveIdx - 1, 0);\n    items.forEach((it, i) => it.classList.toggle('active', i === acActiveIdx));\n    e.preventDefault();\n  } else if (e.key === 'Enter' && acActiveIdx >= 0) {\n    acPick(items[acActiveIdx].dataset.val);\n    e.preventDefault();\n  } else if (e.key === 'Escape') {\n    list.classList.remove('open');\n  }\n}\n\n// ─── TYPE SELECTION ───────────────────────────────────────────────────────────\nfunction selectType(btn) {\n  selectedType = btn.dataset.type;\n  selectedSub = null;\n  document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('selected'));\n  btn.classList.add('selected');\n  document.querySelectorAll('.subtype-card').forEach(c => {\n    c.classList.remove('visible');\n    c.querySelectorAll('.chip').forEach(ch => ch.classList.remove('selected'));\n  });\n  const panel = document.getElementById('sub-' + selectedType);\n  if (panel) {\n    panel.classList.add('visible');\n    renderAddChipRow(selectedType);\n    renderCustomChips(selectedType);\n  }\n  document.getElementById('hint-type').style.display = 'none';\n  document.getElementById('hint-sub').style.display = 'none';\n}\n\nfunction selectChip(chip, type) {\n  if (selectedType !== type) return;\n  document.getElementById('chips-' + type).querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));\n  // also deselect custom chips for this type\n  document.querySelectorAll('#custom-chips-' + type + ' .chip').forEach(c => c.classList.remove('selected'));\n  chip.classList.add('selected');\n  selectedSub = chip.dataset.sub;\n  document.getElementById('hint-sub').style.display = 'none';\n}\n\n// ─── ADD CUSTOM SUBTYPES ──────────────────────────────────────────────────────\nfunction renderCustomChips(type) {\n  const row = document.getElementById('chips-' + type);\n  // Remove existing custom chips container if any\n  const existing = document.getElementById('custom-chips-' + type);\n  if (existing) existing.remove();\n\n  const customs = customSubtypes[type] || [];\n  if (!customs.length) return;\n\n  const wrap = document.createElement('div');\n  wrap.id = 'custom-chips-' + type;\n  wrap.style.display = 'contents';\n  customs.forEach(label => {\n    const chip = document.createElement('button');\n    chip.type = 'button';\n    chip.className = 'chip' + (type === 'shoutout' ? ' shoutout' : '');\n    chip.dataset.sub = label;\n    chip.textContent = label;\n    chip.onclick = () => selectChip(chip, type);\n    wrap.appendChild(chip);\n  });\n  row.appendChild(wrap);\n}\n\nfunction renderAddChipRow(type) {\n  const container = document.getElementById('addrow-' + type);\n  container.innerHTML = '';\n\n  const btnWrap = document.createElement('div');\n  btnWrap.style.display = 'flex';\n  btnWrap.style.gap = '8px';\n  btnWrap.style.alignItems = 'center';\n  btnWrap.style.flexWrap = 'wrap';\n\n  const addBtn = document.createElement('button');\n  addBtn.type = 'button';\n  addBtn.className = 'add-chip-btn';\n  addBtn.textContent = '+ Add subtype';\n\n  const inputWrap = document.createElement('div');\n  inputWrap.className = 'add-chip-input-wrap';\n\n  const inp = document.createElement('input');\n  inp.type = 'text';\n  inp.className = 'add-chip-input';\n  inp.placeholder = 'New subtype…';\n\n  const confirmBtn = document.createElement('button');\n  confirmBtn.type = 'button';\n  confirmBtn.className = 'add-chip-confirm';\n  confirmBtn.textContent = 'Add';\n\n  const cancelBtn = document.createElement('button');\n  cancelBtn.type = 'button';\n  cancelBtn.className = 'add-chip-cancel';\n  cancelBtn.textContent = '✕';\n\n  inputWrap.appendChild(inp);\n  inputWrap.appendChild(confirmBtn);\n  inputWrap.appendChild(cancelBtn);\n  btnWrap.appendChild(addBtn);\n  btnWrap.appendChild(inputWrap);\n  container.appendChild(btnWrap);\n\n  addBtn.onclick = () => {\n    addBtn.style.display = 'none';\n    inputWrap.classList.add('open');\n    inp.focus();\n  };\n\n  cancelBtn.onclick = () => {\n    inputWrap.classList.remove('open');\n    addBtn.style.display = '';\n    inp.value = '';\n  };\n\n  confirmBtn.onclick = () => addCustomChip(type, inp.value, addBtn, inputWrap, inp);\n  inp.onkeydown = (e) => {\n    if (e.key === 'Enter') addCustomChip(type, inp.value, addBtn, inputWrap, inp);\n    if (e.key === 'Escape') cancelBtn.onclick();\n  };\n}\n\nfunction addCustomChip(type, label, addBtn, inputWrap, inp) {\n  label = label.trim();\n  if (!label) return;\n  if (!customSubtypes[type]) customSubtypes[type] = [];\n  if (!customSubtypes[type].includes(label)) {\n    customSubtypes[type].push(label);\n    localStorage.setItem(STORAGE_KEY, JSON.stringify(customSubtypes));\n  }\n  renderCustomChips(type);\n  inputWrap.classList.remove('open');\n  addBtn.style.display = '';\n  inp.value = '';\n}\n\n// ─── FRIDAY TOGGLE ────────────────────────────────────────────────────────────\nfunction toggleFriday() {\n  fridayOn = !fridayOn;\n  document.getElementById('fridayToggle').classList.toggle('on', fridayOn);\n}\n\n// ─── VALIDATION ───────────────────────────────────────────────────────────────\nfunction setErr(id, hasError) {\n  const f = document.getElementById('f-' + id);\n  if (f) f.classList.toggle('error', hasError);\n}\n\n// ─── SUBMIT ───────────────────────────────────────────────────────────────────\nasync function submitForm() {\n  let valid = true;\n  const student = document.getElementById('student').value.trim();\n  const teacher = document.getElementById('teacher').value;\n  const date = document.getElementById('date').value;\n\n  if (!student || !STUDENTS.includes(student)) { setErr('student', true); valid = false; } else { setErr('student', false); }\n  if (!teacher) { setErr('teacher', true); valid = false; } else { setErr('teacher', false); }\n  if (!date) { setErr('date', true); valid = false; } else { setErr('date', false); }\n  if (!selectedType) { document.getElementById('hint-type').style.display = 'block'; valid = false; }\n  if (selectedType && !selectedSub) { document.getElementById('hint-sub').style.display = 'block'; valid = false; }\n  if (!valid) return;\n\n  const typeLabel = { preparation:'Preparation', communication:'Communication', engagement:'Engagement', display:'Display of Learning', shoutout:'Positive Shoutout' }[selectedType];\n  const entry = {\n    student, teacher, date,\n    time: document.getElementById('time').value,\n    type: typeLabel,\n    subtype: selectedSub,\n    notes: document.getElementById('notes').value.trim(),\n    friday: fridayOn ? 'Yes' : 'No',\n    submitted: new Date().toISOString()\n  };\n\n  const btn = document.getElementById('submitBtn');\n\n  if (APPS_SCRIPT_URL) {\n    btn.disabled = true;\n    btn.classList.add('loading');\n    try {\n      await fetch(APPS_SCRIPT_URL, {\n        method: 'POST',\n        mode: 'no-cors',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify(entry)\n      });\n    } catch (err) {\n      console.error('Submission error:', err);\n    }\n    btn.disabled = false;\n    btn.classList.remove('loading');\n  } else {\n    console.log('INCIDENT ENTRY (no URL configured):', JSON.stringify(entry, null, 2));\n  }\n\n  document.getElementById('successDetail').innerHTML =\n    `<strong>${student}<\u002Fstrong> &nbsp;·&nbsp; ${typeLabel} / ${selectedSub}<br>` +\n    `${date}${entry.time ? ' at ' + entry.time : ''}` +\n    (fridayOn ? '<br>📅 Flagged for Friday meeting' : '');\n\n  document.getElementById('formWrap').style.display = 'none';\n  document.getElementById('successScreen').classList.add('visible');\n}\n\n// ─── RESET ────────────────────────────────────────────────────────────────────\nfunction resetForm() {\n  document.getElementById('formWrap').style.display = 'block';\n  document.getElementById('successScreen').classList.remove('visible');\n  document.getElementById('student').value = '';\n  document.getElementById('teacher').value = '';\n  document.getElementById('date').valueAsDate = new Date();\n  const n = new Date();\n  document.getElementById('time').value =\n    String(n.getHours()).padStart(2,'0') + ':' + String(n.getMinutes()).padStart(2,'0');\n  document.getElementById('notes').value = '';\n  selectedType = null; selectedSub = null; fridayOn = false;\n  document.getElementById('fridayToggle').classList.remove('on');\n  document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('selected'));\n  document.querySelectorAll('.subtype-card').forEach(c => {\n    c.classList.remove('visible');\n    c.querySelectorAll('.chip').forEach(ch => ch.classList.remove('selected'));\n  });\n  document.getElementById('hint-type').style.display = 'none';\n  document.getElementById('hint-sub').style.display = 'none';\n}\n<\u002Fscript>\n\n<!--\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\nGOOGLE SHEETS SETUP (one-time, ~5 minutes)\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n1. Open your Google Sheet\n2. Extensions → Apps Script\n3. Paste this code into Code.gs:\n\nfunction doPost(e) {\n  const data = JSON.parse(e.postData.contents);\n  const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();\n  sheet.appendRow([\n    data.submitted, data.date, data.time,\n    data.teacher, data.student,\n    data.type, data.subtype,\n    data.notes, data.friday\n  ]);\n  return ContentService.createTextOutput('ok');\n}\n\n4. Deploy → New deployment → Web app\n   - Execute as: Me\n   - Who has access: Anyone\n5. Copy the Web App URL\n6. Paste it into APPS_SCRIPT_URL at the top of this file's <script> block\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n-->\n\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
